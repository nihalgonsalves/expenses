{
  "name": "@nihalgonsalves/expenses-backend",
  "description": "",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "dev": "run-p 'start' 'db:generate --watch'",
    "start": "node --enable-source-maps --env-file=.env --watch ./src/app.ts",
    "test": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migration": "prisma migrate dev --name",
    "db:sql-lint": "pnpx squawk-cli",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "auth:generate": "BETTER_AUTH_CLI=true auth generate --output=./prisma/schema/auth.prisma",
    "prepare:e2e": "node bin/prepare-ci-e2e.js",
    "prepare:local": "node bin/prepare-local-env.js",
    "prepare:demo": "node bin/demo.ts"
  },
  "dependencies": {
    "@better-auth/core": "1.6.9",
    "@better-auth/passkey": "1.6.9",
    "@better-auth/prisma-adapter": "1.6.9",
    "@bull-board/api": "7.0.0",
    "@bull-board/hono": "7.0.0",
    "@hono/node-server": "2.0.0",
    "@hono/trpc-server": "0.4.2",
    "@nihalgonsalves/expenses-shared": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "@sentry/node": "10.50.0",
    "@sentry/profiling-node": "10.50.0",
    "@simplewebauthn/server": "13.3.0",
    "@trpc/server": "11.16.0",
    "better-auth": "1.6.9",
    "bullmq": "5.75.2",
    "hono": "4.12.15",
    "ioredis": "5.10.1",
    "nanoid": "5.1.9",
    "nodemailer": "8.0.6",
    "rate-limiter-flexible": "11.0.1",
    "rrule": "2.8.1",
    "temporal-polyfill": "0.3.2",
    "ua-parser-js": "2.0.9",
    "web-push": "3.6.7",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "10.4.0",
    "@testcontainers/postgresql": "11.14.0",
    "@testcontainers/redis": "11.14.0",
    "@total-typescript/ts-reset": "0.6.1",
    "@trpc/client": "11.16.0",
    "@types/nodemailer": "8",
    "@types/pem": "1.14.4",
    "@types/web-push": "3.6.4",
    "@vitest/coverage-v8": "4.1.5",
    "auth": "1.6.9",
    "fetch-cookie": "3.2.0",
    "npm-run-all2": "8.0.4",
    "pem": "1.14.8",
    "prisma": "7.8.0",
    "vitest": "4.1.5"
  }
}
