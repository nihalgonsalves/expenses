{
  "name": "@nihalgonsalves/expenses-frontend",
  "description": "",
  "version": "0.0.1",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "pnpm run --stream \"/^dev:.*/\"",
    "dev:vite": "VITE_GIT_COMMIT_SHA=\"$(git rev-parse HEAD)$(git diff --quiet || echo '-dirty')\" VITE_ENV_NAME=local vite --clearScreen=false --host --port 5173",
    "dev:storybook": "storybook dev --port 6006 --no-open",
    "build": "pnpm run --stream \"/^build:.*/\"",
    "build:vite": "vite build",
    "build:storybook": "VITE_STORYBOOK=1 storybook build --output-dir=./build/storybook",
    "gen:assets": "tsx bin/generateAssets.tsx",
    "chromatic": "chromatic --build-script-name='build:storybook'",
    "preview:vite": "vite preview --port 5173",
    "test": "vitest --project=unit",
    "test:storybook": "vitest --project=storybook"
  },
