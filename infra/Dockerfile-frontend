# NODE_VERSION
FROM node:24-slim AS builder

ENV COREPACK_ENABLE_DOWNLOAD_PROMPT=0
RUN corepack enable

ENV PNPM_HOME="/pnpm"
ENV PATH="$PNPM_HOME:$PATH"

RUN mkdir -p /opt/app
WORKDIR /opt/app

COPY package.json .
COPY ./packages/frontend/package.json ./packages/frontend/
COPY ./packages/backend/package.json ./packages/backend/
COPY ./packages/shared/package.json ./packages/shared/
COPY ./packages/e2e/package.json ./packages/e2e/
COPY ./pnpm-lock.yaml .
COPY ./pnpm-workspace.yaml .
COPY ./patches/ ./patches/

RUN --mount=type=cache,id=pnpm,target=/pnpm/store pnpm install --frozen-lockfile

COPY ./tsconfig.json ./tsconfig.base.json ./
COPY ./packages/frontend/ ./packages/frontend/
COPY ./packages/backend/ ./packages/backend/
COPY ./packages/shared/ ./packages/shared/
COPY ./packages/e2e/ ./packages/e2e/

ARG VITE_ENV_NAME=production
ARG VITE_GIT_COMMIT_SHA
ARG VITE_SENTRY_DSN
ARG SENTRY_AUTH_TOKEN
ARG SENTRY_ORG
ARG SENTRY_PROJECT

ENV VITE_ENV_NAME=${VITE_ENV_NAME}
ENV VITE_GIT_COMMIT_SHA=${VITE_GIT_COMMIT_SHA}
ENV VITE_SENTRY_DSN=${VITE_SENTRY_DSN}
ENV SENTRY_AUTH_TOKEN=${SENTRY_AUTH_TOKEN}
ENV SENTRY_ORG=${SENTRY_ORG}
ENV SENTRY_PROJECT=${SENTRY_PROJECT}

RUN pnpm fe build:vite

# the image itself is 24 pinned to LTS
# hadolint ignore=DL3007
FROM gcr.io/distroless/nodejs24:latest
# NODE_VERSION

WORKDIR /app

COPY --from=builder /opt/app/packages/frontend/.output/ ./

EXPOSE 3000

CMD ["--enable-source-maps", "./server/index.mjs"]
