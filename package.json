{
  "name": "@nihalgonsalves/expenses",
  "description": "",
  "version": "0.0.1",
  "type": "module",
  "author": "Nihal Gonsalves <nihal@nihalgonsalves.com>",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm run --stream \"/^dev:.*/\"",
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsgo --build",
    "build:fe": "pnpm fe build:vite",
    "start": "pnpm run \"/^start:.*/\"",
    "start:fe": "pnpm fe start",
    "start:be": "pnpm be start",
    "start:e2e": "VITE_INTEGRATION_TEST=true pnpm run-p start:be 'fe dev:vite'",
    "clean": "git clean -Xdf --exclude='!packages/backend/.env'",
    "test": "vitest",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:oxlint": "oxlint",
    "lint:sherif": "sherif",
    "lint:knip": "knip",
    "lint:format": "prettier . --check",
    "format": "prettier . --write",
    "fe": "pnpm --filter @nihalgonsalves/expenses-frontend --",
    "be": "pnpm --filter @nihalgonsalves/expenses-backend --",
    "e2e": "pnpm --filter @nihalgonsalves/expenses-e2e --",
    "dev:fe": "pnpm fe dev",
    "dev:be": "pnpm be dev",
    "dev:build": "pnpm build:tsc --watch --preserveWatchOutput",
    "validate": "run-p --continue-on-error build 'lint:oxlint --fix' 'lint:sherif' 'lint:knip' 'test --no-watch --reporter=dot' 'format --log-level=warn'"
  },
  "devDependencies": {
    "@nihalgonsalves/esconfig": "0.16.5",
    "@types/node": "24",
    "@typescript/native-preview": "7.0.0-dev.20260322.1",
    "@vitest/coverage-v8": "4.1.0",
    "@vitest/ui": "4.1.0",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-storybook": "10.3.1",
    "eslint-plugin-testing-library": "7.16.1",
    "knip": "6.0.1",
    "lefthook": "2.1.4",
    "npm-run-all2": "8.0.4",
    "oxlint": "1.56.0",
    "oxlint-tsgolint": "0.17.1",
    "prettier": "3.8.1",
    "prettier-plugin-prisma": "5.0.0",
    "prettier-plugin-sql": "0.20.0",
    "prettier-plugin-tailwindcss": "0.7.2",
    "sherif": "1.11.0",
    "type-fest": "5.5.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
