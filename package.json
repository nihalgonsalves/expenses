{
  "name": "@nihalgonsalves/expenses",
  "description": "",
  "version": "0.0.1",
  "type": "module",
  "author": "Nihal Gonsalves <nihal@nihalgonsalves.com>",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.33.2+sha512.a90faf6feeab71ad6c6e57f94e0fe1a12f5dcc22cd754db40ae9593eb6a3e0b6b12e3540218bb37ae083404b1f2ce6db2a4121e979829b4aff94b99f49da1cf8",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "pnpm run --stream \"/^dev:.*/\"",
    "build": "pnpm run \"/^build:.*/\"",
    "build:tsc": "tsgo --build",
    "build:fe": "pnpm fe build:vite",
    "start": "pnpm run \"/^start:.*/\"",
    "start:fe": "pnpm fe start",
    "start:be": "pnpm be start",
    "start:e2e": "VITE_INTEGRATION_TEST=true pnpm run-p start:be 'fe dev:vite'",
    "clean": "git clean -Xdf --exclude='!packages/backend/.env'",
    "test": "vitest",
    "lint": "pnpm run \"/^lint:.*/\"",
    "lint:oxlint": "oxlint",
    "lint:sherif": "sherif",
    "lint:knip": "knip",
    "lint:format": "prettier . --check",
    "format": "prettier . --write",
    "fe": "pnpm --filter @nihalgonsalves/expenses-frontend --",
    "be": "pnpm --filter @nihalgonsalves/expenses-backend --",
    "e2e": "pnpm --filter @nihalgonsalves/expenses-e2e --",
    "dev:fe": "pnpm fe dev",
    "dev:be": "pnpm be dev",
    "dev:build": "pnpm build:tsc --watch --preserveWatchOutput",
    "validate": "run-p --continue-on-error build 'lint:oxlint --fix' 'lint:sherif' 'lint:knip' 'test --no-watch --reporter=dot' 'format --log-level=warn'"
  },
  "devDependencies": {
    "@nihalgonsalves/esconfig": "0.17.3",
    "@types/node": "24",
    "@typescript/native-preview": "7.0.0-dev.20260429.1",
    "@vitest/coverage-v8": "4.1.5",
    "@vitest/ui": "4.1.5",
    "eslint-plugin-jest-dom": "5.5.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-storybook": "10.3.6",
    "eslint-plugin-testing-library": "7.16.2",
    "knip": "6.9.0",
    "lefthook": "2.1.6",
    "npm-run-all2": "8.0.4",
    "oxlint": "1.61.0",
    "oxlint-tsgolint": "0.21.1",
    "prettier": "3.8.3",
    "prettier-plugin-prisma": "5.0.0",
    "prettier-plugin-sql": "0.20.0",
    "prettier-plugin-tailwindcss": "0.8.0",
    "sherif": "1.11.1",
    "type-fest": "5.6.0",
    "typescript": "6.0.3",
    "vitest": "4.1.5"
  }
}
